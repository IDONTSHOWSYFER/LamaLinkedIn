generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  tier      String   @default("free")
  installId String?  @unique
  stripeCustomerId String?
  premiumExpires   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
  sessions  Session[]
}

model Event {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  postId     String?
  authorName String?
  authorTag  String?
  content    String?
  mode       String   @default("assist")
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      String
  likes     Int      @default(0)
  comments  Int      @default(0)
  duration  Int      @default(0)
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
